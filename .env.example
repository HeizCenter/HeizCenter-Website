# n8n Webhook Configuration (Lead Management — Workflow W-01 v2)
# Base URL for n8n webhook endpoints. Default points to production n8n.
N8N_WEBHOOK_BASE_URL=https://auto.heizcenter.de

# Webhook endpoints (constructed from base URL in src/lib/config/webhooks.ts):
# - Contact:   ${N8N_WEBHOOK_BASE_URL}/webhook/leads/contact
# - Quote:     ${N8N_WEBHOOK_BASE_URL}/webhook/leads/quote
# - Emergency: ${N8N_WEBHOOK_BASE_URL}/webhook/leads/emergency
#
# Backend contract (see also src/lib/api/n8n-webhooks.ts):
# - Always returns HTTP 200; clients parse `success` from body.
# - Token values must be exact lowercase snake_case (efh, heizung_neu, ...).

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=HeizCenter

# Contact Information
NEXT_PUBLIC_CONTACT_EMAIL=info@heizcenter.de
NEXT_PUBLIC_CONTACT_PHONE=+49 8234 9665900

# =============================================================================
# DEPRECATED: Odoo Configuration (No longer used - kept for reference)
# =============================================================================
# The website now uses n8n webhooks for lead management instead of direct Odoo.
# The following variables are no longer needed:
#
# NEXT_PUBLIC_ODOO_URL=https://your-odoo-server.com
# ODOO_DATABASE=your_database_name
# ODOO_USERNAME=api@heizcenter.de
# ODOO_API_KEY=your_api_key_here
# ODOO_SALES_TEAM_ID=1
# ODOO_EMERGENCY_TEAM_ID=2
# ODOO_NEWSLETTER_LIST_ID=1
